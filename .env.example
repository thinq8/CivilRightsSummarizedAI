# Clearinghouse API settings
CLEARINGHOUSE_API_TOKEN=your_api_token_here
CLEARINGHOUSE_DATABASE_URL=sqlite:///data/dev.db
CLEARINGHOUSE_API_BASE_URL=https://clearinghouse.net/api/v2p1
CLEARINGHOUSE_API_TIMEOUT=30.0
CLEARINGHOUSE_API_MAX_RETRIES=4
CLEARINGHOUSE_API_BACKOFF_SECONDS=0.5
CLEARINGHOUSE_API_MAX_BACKOFF_SECONDS=8.0
CLEARINGHOUSE_LIVE_CHECKPOINT_KEY=live-default
CLEARINGHOUSE_ARCHIVE_RAW_PAYLOADS=true
CLEARINGHOUSE_CONTINUE_ON_ERROR=true

# Anthropic API (for eval pipeline)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
